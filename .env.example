CARE_OS_DATABASE_BACKEND=postgres
CARE_OS_DATABASE_URL=postgresql+psycopg://careos:careos@localhost:5432/care_os
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
OPENAI_CHAT_MODEL=Qwen/Qwen3-32B
OPENAI_ENABLE_THINKING=false
OPENAI_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
OPENAI_AUDIO_MODEL=Qwen/Qwen2.5-Omni-7B
CARE_OS_MULTIMODAL_AUTO_INCLUDE_CONFIDENCE=0.65
CARE_OS_EMBEDDING_PROVIDER=auto
CARE_OS_EMBEDDING_FALLBACK_PROVIDER=hash
CARE_OS_GENERATION_PRIMARY_PROVIDER=openai_compatible
CARE_OS_GENERATION_SECONDARY_PROVIDER=rule_fallback
CARE_OS_RERANK_PROVIDER=heuristic
CARE_OS_CORPUS_VERSION=v2
CARE_OS_FORCE_RULE_FALLBACK=false
